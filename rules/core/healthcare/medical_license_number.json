{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "healthcare.medical_license_number",
  "qualified_id": "core.healthcare.medical_license_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "Medical License Number",
  "description": "Detects state medical board license numbers for physicians and healthcare providers. Format: 1-3 letters + 4-9 digits (varies by state).",
  "category_id": "healthcare",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "healthcare-industry",
    "hipaa",
    "healthcare",
    "phi-detection",
    "production"
  ],
  "metadata": {
    "country": "United States",
    "official_name": "State Medical License Number",
    "phi_category": "Provider Identifier",
    "hipaa_category": "Certificate/license numbers",
    "pattern_source": "HIPAA Privacy Rule 45 CFR 164.514(b)(2)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "target": "content",
    "pattern": {
      "pattern": "(?i)\\b(?:medical\\s*)?license\\s*(?:number|#)?\\s*:?\\s*([A-Z]{1,3}\\d{4,9})\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "MED_LIC",
          "reversible": false
        }
      },
      "message": "Medical license number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-28T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "US"
  ]
}
