{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "healthcare.health_plan_beneficiary_number",
  "qualified_id": "core.healthcare.health_plan_beneficiary_number",
  "type": "rule",
  "version": "3.1.0",
  "name": "Health Plan Beneficiary Number",
  "description": "Detects health plan group numbers and beneficiary identifiers. Format: 5-15 alphanumeric characters with contextual keywords (group, plan, beneficiary).",
  "category_id": "healthcare",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "hipaa",
    "healthcare",
    "phi-detection",
    "production"
  ],
  "metadata": {
    "country": "United States",
    "official_name": "Health Plan Beneficiary Number",
    "phi_category": "Health Plan Beneficiary Number",
    "hipaa_category": "Health plan beneficiary numbers",
    "pattern_source": "HIPAA Privacy Rule 45 CFR 164.514(b)(2)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "target": "content",
    "pattern": {
      "pattern": "(?i)\\b(?:group|plan|beneficiary)\\s*(?:number|#|no)?\\s*:\\s*([A-Z0-9]{5,15})\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "HPBN",
          "reversible": false
        }
      },
      "message": "Health plan beneficiary number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-28T00:00:00Z",
  "updated_at": "2026-03-18T00:00:00Z",
  "regions": [
    "US"
  ]
}
