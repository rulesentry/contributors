{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "healthcare.medicaid_id",
  "qualified_id": "core.healthcare.medicaid_id",
  "type": "rule",
  "version": "3.0.1",
  "name": "Medicaid ID Number",
  "description": "Detects state Medicaid identification numbers with contextual keywords. Format varies by state, typically 8-13 alphanumeric characters. Pattern looks for 'medicaid' keyword followed by identifier.",
  "category_id": "healthcare",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "healthcare-industry",
    "hipaa",
    "healthcare",
    "phi-detection",
    "production"
  ],
  "metadata": {
    "country": "United States",
    "official_name": "Medicaid Identification Number",
    "phi_category": "Health Plan Beneficiary Number",
    "hipaa_category": "Health plan beneficiary numbers",
    "pattern_source": "HIPAA Privacy Rule 45 CFR 164.514(b)(2)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "target": "content",
    "pattern": {
      "pattern": "(?i)\\b(?:medicaid\\s*(?:id|number|#)?\\s*:?\\s*)([A-Z0-9]{8,13})\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "MEDICAID",
          "reversible": false
        }
      },
      "message": "Medicaid ID tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-28T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "US"
  ]
}
