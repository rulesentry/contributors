{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "healthcare.health_insurance_number",
  "qualified_id": "core.healthcare.health_insurance_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "Health Insurance Number",
  "description": "Detects health insurance/plan numbers with explicit context. Includes member ID, policy number, subscriber ID. HIPAA PHI.",
  "category_id": "healthcare",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "healthcare-industry",
    "hipaa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "HIPAA Protected Health Information (PHI)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:Health\\s+Insurance|Insurance\\s+Policy|Member\\s+ID|Subscriber\\s+ID|Policy\\s+Number)[:\\s]+[A-Z0-9-]{6,20}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "INSURANCE",
          "reversible": false
        }
      },
      "message": "Health insurance number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
