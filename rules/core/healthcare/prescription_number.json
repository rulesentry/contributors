{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "healthcare.prescription_number",
  "qualified_id": "core.healthcare.prescription_number",
  "type": "rule",
  "version": "3.0.0",
  "name": "Prescription Number (Rx)",
  "description": "Detects prescription numbers with 'Rx:', 'Rx#', or 'Prescription Number:' context. HIPAA PHI.",
  "category_id": "healthcare",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "hipaa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "HIPAA Protected Health Information (PHI)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:Rx|Prescription\\s+(?:Number|No\\.?|#))[:\\s]+[A-Z0-9-]{6,15}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "RX",
          "reversible": false
        }
      },
      "message": "Prescription number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-13T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
