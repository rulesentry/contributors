{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "financial.account_number",
  "qualified_id": "core.financial.account_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "Bank Account Number (Generic)",
  "description": "Detects generic bank account numbers (8-17 digits). This is a broad pattern that may have false positives; use with caution or combine with context filters.",
  "category_id": "financial",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "financial-industry",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "note": "Generic pattern - may need context-specific tuning",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:account|acct)(?:\\s+(?:number|no|#))?[:\\s]+\\d{8,17}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "mask",
        "params": {
          "mask_char": "*",
          "visible_suffix": 4
        }
      },
      "message": "Bank account number masked, last 4 digits visible"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
