{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "financial.card_expiration",
  "qualified_id": "core.financial.card_expiration",
  "type": "rule",
  "version": "1.0.1",
  "status": "active",
  "name": "Card Expiration Date",
  "summary": "Detects card expiration dates by keyword context (e.g., 'expiration 09/27')",
  "description": "Detects payment card expiration dates by keyword proximity. Matches dates following labels such as 'exp:', 'expiry:', 'expiration:', 'valid thru:', 'valid through:', 'valid until:'. Context-anchored to avoid false positives on standalone date-like strings.",
  "category_id": "financial",
  "severity": "high",
  "profiles": [
    "financial-industry",
    "pci-dss",
    "production"
  ],
  "regions": [
    "GLOBAL"
  ],
  "tags": [
    "payment-card",
    "expiration",
    "pci-dss",
    "context-anchored"
  ],
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "(?:exp(?:ir(?:y|ation))?|valid\\s+(?:thru|through|until))[:\\s]*(\\d{2}[/-]\\d{2,4})",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "Card expiration date redacted — PCI-DSS sensitive data",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[EXPIRY_REDACTED]"
        }
      }
    }
  },
  "created_at": "2026-03-19T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z"
}
