{
  "_note": "Overlaps with credentials.aws_secret_access_key. The credentials/ version is canonical for secret detection; this version retained for category-based policy inclusion.",
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.aws_secret_access_key",
  "qualified_id": "core.digital_identity.aws_secret_access_key",
  "type": "rule",
  "version": "3.0.1",
  "name": "AWS Secret Access Key",
  "description": "Detects AWS Secret Access Keys (40-character base64 strings). Exposure combined with Access Key ID grants full AWS account access.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "technology-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "40 characters (base64)",
    "risk": "Complete AWS account compromise",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:aws_secret_access_key|AWS_SECRET_ACCESS_KEY)[:\\s=]+[A-Za-z0-9/+=]{40}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[AWS_SECRET_ACCESS_KEY]"
        }
      },
      "message": "AWS Secret Access Key redacted - must never be exposed (critical security risk)"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
