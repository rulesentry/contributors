{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.google_oauth_client_secret",
  "qualified_id": "core.digital_identity.google_oauth_client_secret",
  "type": "rule",
  "version": "3.0.1",
  "name": "Google OAuth Client Secret",
  "description": "Detects Google OAuth 2.0 client secrets. Used for server-to-server authentication with Google services.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "technology-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "risk": "OAuth flow compromise, unauthorized Google service access",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 95,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:client_secret|GOOGLE_CLIENT_SECRET)[:\\s=]+[A-Za-z0-9_-]{24,}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[GOOGLE_OAUTH_CLIENT_SECRET]"
        }
      },
      "message": "Google OAuth Client Secret redacted - redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
