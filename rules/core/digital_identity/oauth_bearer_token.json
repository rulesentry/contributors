{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.oauth_bearer_token",
  "qualified_id": "core.digital_identity.oauth_bearer_token",
  "type": "rule",
  "version": "3.0.1",
  "name": "OAuth Bearer Token",
  "description": "Detects OAuth 2.0 Bearer tokens in Authorization headers. Format: Bearer [token]. Used for API authentication.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "technology-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "Bearer [A-Za-z0-9_-]+",
    "risk": "API access, session hijacking",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\bBearer\\s+[A-Za-z0-9_\\-\\.=]+\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "OAUTH_TOKEN",
          "reversible": true
        }
      },
      "message": "OAuth Bearer token tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
