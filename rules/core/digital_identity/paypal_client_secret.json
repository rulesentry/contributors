{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.paypal_client_secret",
  "qualified_id": "core.digital_identity.paypal_client_secret",
  "type": "rule",
  "version": "3.0.1",
  "name": "PayPal Client Secret",
  "description": "Detects PayPal REST API client secrets. Used with client ID for PayPal payment processing.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "technology-sector",
    "production",
    "pci-dss"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "EP[A-Za-z0-9_-]{30,}",
    "risk": "Payment processing access, financial fraud",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 95,
    "target": "content",
    "pattern": {
      "pattern": "\\bEP[A-Za-z0-9_-]{30,}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[PAYPAL_CLIENT_SECRET]"
        }
      },
      "message": "PayPal Client Secret redacted - redacted (financial security risk)"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
