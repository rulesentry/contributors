{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.basic_auth_credentials",
  "qualified_id": "core.digital_identity.basic_auth_credentials",
  "type": "rule",
  "version": "3.0.1",
  "name": "HTTP Basic Auth Credentials",
  "description": "Detects HTTP Basic Authentication credentials in Authorization headers. Format: Basic [base64]. Contains username:password.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "technology-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "Basic [base64-encoded username:password]",
    "risk": "Plain credentials exposure",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 90,
    "target": "content",
    "pattern": {
      "pattern": "\\bBasic\\s+[A-Za-z0-9+/=]{12,}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[BASIC_AUTH_CREDENTIALS]"
        }
      },
      "message": "HTTP Basic Auth credentials redacted - redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
