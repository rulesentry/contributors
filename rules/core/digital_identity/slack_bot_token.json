{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "digital_identity.slack_bot_token",
  "qualified_id": "core.digital_identity.slack_bot_token",
  "type": "rule",
  "version": "3.0.1",
  "name": "Slack Bot Token",
  "description": "Detects Slack Bot tokens. Format: xoxb-. Can read messages, post messages, access workspace data.",
  "category_id": "digital_identity",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "technology-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "xoxb-[0-9]+-[0-9]+-[A-Za-z0-9]+",
    "risk": "Workspace data access, message reading/posting",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\bxoxb-[0-9]+-[0-9]+-[A-Za-z0-9]+\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[SLACK_BOT_TOKEN]"
        }
      },
      "message": "Slack Bot Token redacted - redacted"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "GLOBAL"
  ]
}
