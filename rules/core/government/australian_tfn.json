{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.australian_tfn",
  "qualified_id": "core.government.australian_tfn",
  "type": "rule",
  "version": "3.0.1",
  "name": "Australian Tax File Number (TFN)",
  "description": "Detects Australian Tax File Numbers with MOD-11 checksum validation. Format: XXX-XXX-XXX (9 digits).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "privacy-act-au",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX-XXX-XXX (9 digits)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:tfn|tax\\s+file\\s+number)[:\\s]+\\d{3}[-\\s]?\\d{3}[-\\s]?\\d{3}\\b",
      "engine": "regex",
      "validator": "australian_tfn_mod11",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "TFN",
          "reversible": false
        }
      },
      "message": "Australian TFN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "AU"
  ]
}
