{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.us_immigration_number",
  "qualified_id": "core.government.us_immigration_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "US Immigration Number (A-Number)",
  "description": "Detects US Alien Registration Numbers (A-Numbers) used by USCIS. Format: 'A' prefix followed by 7-9 digits. Context-anchored to require keyword prefix (A#, alien registration, etc.) to reduce false positives.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction IMMIGRATION_NUMBER pattern",
    "attribution": "USCIS Alien Registration Number format",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "(?:A[-\\s]?#?|alien\\s+(?:registration\\s+)?(?:no|number))[-\\s:]*\\d{7,9}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "ANUMBER",
          "reversible": false
        }
      },
      "message": "US immigration number (A-Number) tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "US"
  ]
}
