{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.us_passport",
  "qualified_id": "core.government.us_passport",
  "type": "rule",
  "version": "3.0.1",
  "name": "US Passport Number",
  "description": "Detects US passport numbers. Format: 9 digits (old) or 1 letter + 8 digits (new).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "ccpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXXXXXXXX or AXXXXXXXX",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 90,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:passport|passport\\s+no|passport\\s+number)[:\\s]+(?:[A-Z]\\d{8}|\\d{9})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "PASSPORT",
          "reversible": false
        }
      },
      "message": "US passport number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "US"
  ]
}
