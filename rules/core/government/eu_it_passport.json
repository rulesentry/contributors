{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_it_passport",
  "qualified_id": "core.government.eu_it_passport",
  "type": "rule",
  "version": "3.0.1",
  "name": "Italian Passport Number",
  "description": "Detects Italian passport numbers. Format: 2 letters followed by 7 digits. Context-anchored to reduce false positives from this short pattern.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "metadata": {
    "country": "Italy",
    "pattern_source": "Based on Presidio ItPassportRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "AA1234567 (2 letters + 7 digits)",
    "official_name": "Passaporto",
    "note": "Weak pattern; context prefix required to reduce false positives",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "(?:passaporto|passport|documento\\s+di\\s+viaggio)[\\s:# -]*([A-Z]{2}\\d{7})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IT_PASSPORT",
          "reversible": false
        }
      },
      "message": "Italian passport number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "IT"
  ]
}
