{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.americas_colombia_cc",
  "qualified_id": "core.government.americas_colombia_cc",
  "type": "rule",
  "version": "3.0.1",
  "name": "Colombian Citizenship Card (Cédula de Ciudadanía)",
  "description": "Detects Colombian national ID card numbers.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Colombia",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "8-10 digits (formatted with dots or spaces)",
    "official_name": "Cédula de Ciudadanía",
    "note": "Law 1581 Personal Data Protection",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{1,3}[.,\\s]?[0-9]{3}[.,\\s]?[0-9]{3}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CO_CC",
          "reversible": false
        }
      },
      "message": "Colombia CC tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "CO"
  ]
}
