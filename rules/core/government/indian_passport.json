{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.indian_passport",
  "qualified_id": "core.government.indian_passport",
  "type": "rule",
  "version": "3.0.0",
  "name": "Indian Passport Number",
  "description": "Detects Indian passport numbers. Format: 1 letter + 2 digits (first non-zero) + optional space + 4 digits + 1 digit (non-zero). Context-anchored to reduce false positives.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "metadata": {
    "country": "India",
    "pattern_source": "Based on Presidio InPassportRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "A1234567 (letter + 7 digits, first and last non-zero)",
    "note": "Weak pattern; context prefix required to reduce false positives",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "(?:passport|indian\\s+passport|passport\\s+(?:no|number|num|#))[\\s:# -]*([A-Z][1-9]\\d\\s?\\d{4}[1-9])\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IN_PASSPORT",
          "reversible": false
        }
      },
      "message": "Indian passport number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-17T00:00:00Z",
  "regions": [
    "IN"
  ]
}
