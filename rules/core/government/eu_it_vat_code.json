{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_it_vat_code",
  "qualified_id": "core.government.eu_it_vat_code",
  "type": "rule",
  "version": "3.0.0",
  "name": "Italian VAT Code (Partita IVA)",
  "description": "Detects Italian VAT identification numbers (Partita IVA) with Luhn checksum validation. Format: 11 digits.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "gdpr",
    "production"
  ],
  "metadata": {
    "country": "Italy",
    "pattern_source": "Based on Presidio ItVatCodeRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "validator_algorithm": "Luhn checksum (standard ISO/IEC 7812-1)",
    "format": "11 digits",
    "official_name": "Partita IVA",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b\\d{11}\\b",
      "engine": "regex",
      "validator": "luhn",
      "validator_params": {
        "strip_chars": " _",
        "reject_keywords": ["00000000000"]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IT_VAT",
          "reversible": false
        }
      },
      "message": "Italian Partita IVA tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-17T00:00:00Z",
  "regions": [
    "IT"
  ]
}
