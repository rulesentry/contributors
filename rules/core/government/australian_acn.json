{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.australian_acn",
  "qualified_id": "core.government.australian_acn",
  "type": "rule",
  "version": "3.0.1",
  "name": "Australian Company Number (ACN)",
  "description": "Detects Australian Company Numbers with MOD-10 complement checksum validation. Format: 9 digits (XXX XXX XXX) preceded by context keywords.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "ASIC Australian Company Number format",
    "attribution": "Australian Securities and Investments Commission (ASIC)",
    "format": "9 digits (XXX XXX XXX)",
    "validator_algorithm": "Weighted sum MOD-10 with complement check digit",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:ACN|Australian\\s+Company\\s+Number)[:\\s]+\\d{3}\\s?\\d{3}\\s?\\d{3}\\b",
      "engine": "regex",
      "validator": "acn_mod10",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "ACN_AU",
          "reversible": false
        }
      },
      "message": "Australian Company Number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "AU"
  ]
}
