{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.asia_singapore_uen",
  "qualified_id": "core.government.asia_singapore_uen",
  "type": "rule",
  "version": "3.0.0",
  "name": "Singapore Unique Entity Number (UEN)",
  "description": "Detects Singapore Unique Entity Numbers in three formats: Format A (8 digits + letter), Format B (9 digits + letter), Format C (T/S prefix + 2 digits + 2 entity letters + 4 digits + letter).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "metadata": {
    "country": "Singapore",
    "pattern_source": "Based on Presidio SgUenRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "Format A: 12345678A | Format B: 123456789A | Format C: T12LP1234A",
    "official_name": "Unique Entity Number (UEN)",
    "note": "Three distinct checksum algorithms (one per format) are too complex for a single declarative validator; deferred to future implementation",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 65,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:\\d{8}[A-Z]|\\d{9}[A-Z]|[TS]\\d{2}[A-Z]{2}\\d{4}[A-Z])\\b",
      "engine": "regex",
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": ["example", "sample", "test", "demo"]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "SG_UEN",
          "reversible": false
        }
      },
      "message": "Singapore UEN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-17T00:00:00Z",
  "regions": [
    "SG"
  ]
}
