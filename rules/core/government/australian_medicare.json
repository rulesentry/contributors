{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.australian_medicare",
  "qualified_id": "core.government.australian_medicare",
  "type": "rule",
  "version": "3.0.1",
  "name": "Australian Medicare Number",
  "description": "Detects Australian Medicare card numbers with MOD-10 checksum validation. Format: first digit 2-6, followed by 9 digits, with optional /N issue number suffix.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on Presidio AuMedicareRecognizer",
    "attribution": "Services Australia Medicare card number format",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b[2-6]\\d{3}\\s?\\d{5}\\s?\\d(?:\\/\\d)?\\b",
      "engine": "regex",
      "validator": "australian_medicare_mod10"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "MEDICARE_AU",
          "reversible": false
        }
      },
      "message": "Australian Medicare number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "AU"
  ]
}
