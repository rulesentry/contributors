{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.australian_abn",
  "qualified_id": "core.government.australian_abn",
  "type": "rule",
  "version": "3.0.1",
  "name": "Australian Business Number (ABN)",
  "description": "Detects Australian Business Numbers with MOD-89 checksum validation. Format: 11 digits (XX XXX XXX XXX) preceded by context keywords.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Australian Business Register ABN format",
    "attribution": "Australian Business Register (ABR)",
    "format": "11 digits (XX XXX XXX XXX)",
    "validator_algorithm": "Weighted sum MOD-89 with first digit adjustment",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:ABN|Australian\\s+Business\\s+Number)[:\\s]+\\d{2}\\s?\\d{3}\\s?\\d{3}\\s?\\d{3}\\b",
      "engine": "regex",
      "validator": "abn_mod89",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "ABN_AU",
          "reversible": false
        }
      },
      "message": "Australian Business Number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "AU"
  ]
}
