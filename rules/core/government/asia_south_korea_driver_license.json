{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.asia_south_korea_driver_license",
  "qualified_id": "core.government.asia_south_korea_driver_license",
  "type": "rule",
  "version": "3.0.1",
  "name": "South Korean Driver License Number",
  "description": "Detects South Korean driver license numbers with region code validation. Format: 2-digit region code + 2-digit year + 6-digit serial + 2-digit check.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "South Korea",
    "pattern_source": "Based on Presidio KrDriverLicenseRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "validator_algorithm": "Region code prefix check (valid codes: 11-26, 28)",
    "format": "12-34-567890-12 (region + year + serial + check)",
    "official_name": "운전면허번호 (Driver License Number)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b\\d{2}-?\\d{2}-?\\d{6}-?\\d{2}\\b",
      "engine": "regex",
      "validator": "kr_driver_license_region"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "KR_DL",
          "reversible": false
        }
      },
      "message": "Korean driver license number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "KR"
  ]
}
