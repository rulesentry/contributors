{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.asia_japanese_my_number",
  "qualified_id": "core.government.asia_japanese_my_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "Japanese My Number (Individual Number)",
  "description": "Detects Japanese My Number identification with check digit validation. Used for social security, taxation, and disaster response.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Japan",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "Check digit calculated using Luhn-like MOD-11",
    "format": "12 digits (e.g., 123456789012)",
    "official_name": "マイナンバー (My Number)",
    "note": "Act on the Use of Numbers requires strict protection",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 90,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{12}\\b",
      "engine": "regex",
      "validator": "my_number_checksum"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[JP_MY_NUMBER]"
        }
      },
      "message": "Japanese My Number redacted per Act on Use of Numbers"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "JP"
  ]
}
