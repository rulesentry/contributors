{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.africa_nigeria_vehicle_registration",
  "qualified_id": "core.government.africa_nigeria_vehicle_registration",
  "type": "rule",
  "version": "3.0.0",
  "name": "Nigerian Vehicle Registration Plate",
  "description": "Detects Nigerian vehicle registration plate numbers. Format: 3-letter LGA code + 3 digits + 2-letter code.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "country": "Nigeria",
    "pattern_source": "Based on Presidio NgVehicleRegistrationRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "ABC-123DE (LGA code + serial + year/batch code)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 50,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z]{3}[- ]?\\d{3}[- ]?[A-Z]{2}\\b",
      "engine": "regex",
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": ["example", "sample", "test", "demo"]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[NG_VEHICLE_REG]"
        }
      },
      "message": "Nigerian vehicle registration plate redacted"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-17T00:00:00Z",
  "regions": [
    "NG"
  ]
}
