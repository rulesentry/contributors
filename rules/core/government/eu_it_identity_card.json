{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_it_identity_card",
  "qualified_id": "core.government.eu_it_identity_card",
  "type": "rule",
  "version": "3.0.1",
  "name": "Italian Identity Card Number",
  "description": "Detects Italian identity card numbers in three formats: paper (AA 1234567), CIE 2.0 (1234567AA), and CIE 3.0 (AA12345AA). Context-anchored to reduce false positives.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "metadata": {
    "country": "Italy",
    "pattern_source": "Based on Presidio ItIdentityCardRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "Paper: AA 1234567 | CIE 2.0: 1234567AA | CIE 3.0: AA12345AA",
    "official_name": "Carta d'Identità",
    "note": "Weak patterns; context prefix required to reduce false positives",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "(?:carta\\s+d[i']?\\s*identit[àa]|identity\\s+card|documento\\s+(?:di\\s+)?riconoscimento|\\bCIE\\b)[\\s:# -]*([A-Z]{2}\\s?\\d{7}|\\d{7}[A-Z]{2}|[A-Z]{2}\\d{5}[A-Z]{2})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IT_ID",
          "reversible": false
        }
      },
      "message": "Italian identity card number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "IT"
  ]
}
