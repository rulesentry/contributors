{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.uk_company_number",
  "qualified_id": "core.government.uk_company_number",
  "type": "rule",
  "version": "3.0.1",
  "name": "UK Companies House Number",
  "description": "Detects UK company registration numbers issued by Companies House. Format: 8 digits or 2-letter prefix (e.g., SC, NI, OC) followed by 6 digits, preceded by context keywords.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "uk-dpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "Companies House registration number format",
    "attribution": "UK Companies House",
    "format": "8 digits or 2-letter prefix + 6 digits",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 60,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:company\\s+number|CRN|companies\\s+house)[:\\s]+(?:[A-Z]{2}\\d{6}|\\d{8})\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[UK_COMPANY_NUMBER]"
        }
      },
      "message": "UK Companies House number redacted"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "UK"
  ]
}
