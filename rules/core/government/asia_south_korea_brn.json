{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.asia_south_korea_brn",
  "qualified_id": "core.government.asia_south_korea_brn",
  "type": "rule",
  "version": "3.0.1",
  "name": "South Korean Business Registration Number (BRN)",
  "description": "Detects Korean Business Registration Numbers (사업자등록번호). Format: 3 digits + dash + 2 digits + dash + 5 digits.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "South Korea",
    "pattern_source": "Based on Presidio KrBrnRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "validator_algorithm": "Custom MOD-10 with magic keys [1,3,7,1,3,7,1,3,5] and special 9th-digit handling. Deferred to future hardcoded validator.",
    "format": "123-45-67890 (3+2+5 digits with dashes)",
    "official_name": "사업자등록번호 (Business Registration Number)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b\\d{3}-\\d{2}-\\d{5}\\b",
      "engine": "regex",
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": [
          "example",
          "sample",
          "test",
          "demo",
          "000-00-00000"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "KR_BRN",
          "reversible": false
        }
      },
      "message": "Korean BRN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "KR"
  ]
}
