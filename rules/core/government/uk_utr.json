{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.uk_utr",
  "qualified_id": "core.government.uk_utr",
  "type": "rule",
  "version": "3.0.1",
  "name": "UK Unique Taxpayer Reference (UTR)",
  "description": "Detects UK Unique Taxpayer References issued by HMRC. Format: 10 digits preceded by context keywords (UTR, unique taxpayer reference, tax reference).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "uk-dpa",
    "production"
  ],
  "metadata": {
    "pattern_source": "HMRC UTR format specification",
    "attribution": "HM Revenue & Customs",
    "format": "10 digits with context keywords",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:UTR|unique\\s+taxpayer\\s+reference|tax\\s+reference)[:\\s]+\\d{10}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "UTR_UK",
          "reversible": false
        }
      },
      "message": "UK Unique Taxpayer Reference tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "UK"
  ]
}
