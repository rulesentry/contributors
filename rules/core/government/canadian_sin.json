{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.canadian_sin",
  "qualified_id": "core.government.canadian_sin",
  "type": "rule",
  "version": "3.1.1",
  "name": "Canadian Social Insurance Number (SIN)",
  "description": "Detects Canadian Social Insurance Numbers with MOD-10 checksum validation. Format: XXX-XXX-XXX (9 digits).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "pipeda",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXX-XXX-XXX (9 digits)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "(?:(?:sin|s\\.i\\.n\\.|social\\s+insurance(?:\\s+number)?)[:\\s#-]*)?\\b\\d{3}[-\\s]?\\d{3}[-\\s]?\\d{3}\\b",
      "engine": "regex",
      "validator": "canadian_sin_mod10"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "SIN",
          "reversible": false
        }
      },
      "message": "Canadian SIN tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "CA"
  ]
}
