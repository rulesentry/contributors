{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.china_id_card",
  "qualified_id": "core.government.china_id_card",
  "type": "rule",
  "version": "3.0.1",
  "name": "China Resident Identity Card",
  "description": "Detects Chinese national ID card numbers with GB 11643-1999 checksum validation. Format: 18 digits (6 region + 8 DOB + 3 sequential + 1 checksum).",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "RRRRRRYYYYMMDDSSSC (18 characters)",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 100,
    "target": "content",
    "pattern": {
      "pattern": "\\b\\d{17}[\\dXx]\\b",
      "engine": "regex",
      "validator": "china_id_gb11643"
    },
    "effect": {
      "type": "transform",
      "rationale": "verification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CN_ID",
          "reversible": false
        }
      },
      "message": "China ID card number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "CN"
  ]
}
