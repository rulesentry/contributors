{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.nz_ird",
  "qualified_id": "core.government.nz_ird",
  "type": "rule",
  "version": "3.0.1",
  "name": "New Zealand IRD Number",
  "description": "Detects New Zealand Inland Revenue Department (IRD) numbers. Format: 8 or 9 digits preceded by context keywords. MOD-11 checksum validator may be added in follow-up.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "pattern_source": "NZ Inland Revenue IRD number format",
    "attribution": "Inland Revenue Department (Te Tari Taake)",
    "format": "8-9 digits with context keywords",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 75,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:IRD|IRD\\s+number|tax\\s+number)[:\\s]+\\d{8,9}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IRD_NZ",
          "reversible": false
        }
      },
      "message": "New Zealand IRD number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "NZ"
  ]
}
