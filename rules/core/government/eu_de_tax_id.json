{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_de_tax_id",
  "qualified_id": "core.government.eu_de_tax_id",
  "type": "rule",
  "version": "3.0.1",
  "status": "active",
  "name": "German Tax ID (Steueridentifikationsnummer)",
  "summary": "Detects German tax identification numbers (11 digits) with context markers",
  "description": "Detects German tax identification numbers. Format: 11 digits.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "regions": [
    "DE"
  ],
  "tags": [
    "pii",
    "government-id",
    "tax",
    "gdpr"
  ],
  "metadata": {
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "XXXXXXXXXXX (11 digits)"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:steuer|tax|steuernummer|tax\\s+id)[:\\s]+\\d{11}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "message": "German tax ID tokenized for de-identification",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "DE_TAX",
          "reversible": false
        }
      }
    }
  },
  "created_at": "2026-02-10T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z"
}
