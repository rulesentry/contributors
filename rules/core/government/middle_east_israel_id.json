{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.middle_east_israel_id",
  "qualified_id": "core.government.middle_east_israel_id",
  "type": "rule",
  "version": "3.0.1",
  "name": "Israeli ID Number (Teudat Zehut)",
  "description": "Detects Israeli identity card numbers with Luhn checksum validation.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Israel",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "Luhn checksum (last digit)",
    "format": "9 digits (padded with leading zeros if needed)",
    "official_name": "תעודת זהות (Teudat Zehut)",
    "note": "Privacy Protection Law, 1981",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{9}\\b",
      "engine": "regex",
      "validator": "luhn"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IL_ID",
          "reversible": false
        }
      },
      "message": "Israel ID tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "IL"
  ]
}
