{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.pl_pesel",
  "qualified_id": "core.government.pl_pesel",
  "type": "rule",
  "version": "3.0.1",
  "name": "Polish PESEL Number",
  "description": "Detects Polish national identification numbers (PESEL) with explicit context. PESEL is an 11-digit number encoding birth date, ordinal number, and checksum, issued to all residents of Poland.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "critical",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "metadata": {
    "format": "11 digits: YYMMDDWWWWX (birth date + sequence + checksum)",
    "note": "GDPR - personal data, Polish UODO supervision",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 90,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:PESEL|numer PESEL)[:\\s]+\\d{11}\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "PESEL",
          "reversible": false
        }
      },
      "message": "Polish PESEL number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-13T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "PL"
  ]
}
