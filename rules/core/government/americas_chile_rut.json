{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.americas_chile_rut",
  "qualified_id": "core.government.americas_chile_rut",
  "type": "rule",
  "version": "3.0.1",
  "name": "Chilean RUT (Rol Único Tributario)",
  "description": "Detects Chilean unique tax role numbers with check digit (Modulo 11) validation.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Chile",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "Modulo 11 check digit (can be 0-9 or K)",
    "format": "7-8 digits + check digit (formatted: XX.XXX.XXX-X)",
    "official_name": "Rol Único Tributario",
    "note": "Law 19,628 Protection of Privacy",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{1,2}[.]?[0-9]{3}[.]?[0-9]{3}[-]?[0-9K]\\b",
      "engine": "regex",
      "validator": "rut_mod11",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "CL_RUT",
          "reversible": false
        }
      },
      "message": "Chile RUT tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "CL"
  ]
}
