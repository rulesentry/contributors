{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.americas_mexico_curp",
  "qualified_id": "core.government.americas_mexico_curp",
  "type": "rule",
  "version": "3.0.1",
  "name": "Mexican CURP (Clave Única de Registro de Población)",
  "description": "Detects Mexican unique population registry codes with check digit validation. Encodes name, birth date, gender, and birthplace.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Mexico",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "validator_algorithm": "Check digit calculated from alphanumeric encoding",
    "format": "18 characters (4 letters + 6 digits + 1 letter + 5 alphanumeric + 1 digit)",
    "official_name": "Clave Única de Registro de Población",
    "note": "Encodes surname, name, birth date, gender, state",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 85,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z]{4}[0-9]{6}[HM][A-Z]{2}[A-Z0-9]{3}[A-Z0-9][0-9]\\b",
      "engine": "regex",
      "validator": "curp_checksum"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "MX_CURP",
          "reversible": false
        }
      },
      "message": "Mexico CURP tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "MX"
  ]
}
