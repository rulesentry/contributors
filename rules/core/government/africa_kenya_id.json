{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.africa_kenya_id",
  "qualified_id": "core.government.africa_kenya_id",
  "type": "rule",
  "version": "3.0.1",
  "name": "Kenyan National ID Number",
  "description": "Detects Kenyan national identification card numbers.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "production"
  ],
  "metadata": {
    "country": "Kenya",
    "pattern_source": "Based on OpenRedaction community patterns",
    "attribution": "https://github.com/openredact/openredact",
    "format": "7-8 digits",
    "official_name": "National ID Number",
    "note": "Data Protection Act, 2019",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "\\b[0-9]{7,8}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "KE_ID",
          "reversible": false
        }
      },
      "message": "Kenya ID tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-01-27T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "KE"
  ]
}
