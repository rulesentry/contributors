{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_es_nie",
  "qualified_id": "core.government.eu_es_nie",
  "type": "rule",
  "version": "3.0.1",
  "name": "Spanish NIE (Foreigner Identity Number)",
  "description": "Detects Spanish Número de Identidad de Extranjero. Format: X/Y/Z prefix + 7 digits + check letter. Uses MOD-23 lookup table (same as DNI) after letter-to-digit substitution.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "high",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "metadata": {
    "country": "Spain",
    "pattern_source": "Based on Presidio EsNieRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "validator_algorithm": "MOD-23 with X→0, Y→1, Z→2 prefix substitution and letter lookup table TRWAGMYFPDXBNJZSQVHLCKE",
    "format": "X1234567A (X/Y/Z + 7 digits + check letter)",
    "official_name": "Número de Identidad de Extranjero (NIE)",
    "note": "Checksum validation deferred to future hardcoded validator; pattern structure provides moderate precision",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 80,
    "target": "content",
    "pattern": {
      "pattern": "\\b[XYZ]\\d{7}[A-Z]\\b",
      "engine": "regex",
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": [
          "example",
          "sample",
          "test",
          "demo"
        ]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "ES_NIE",
          "reversible": false
        }
      },
      "message": "Spanish NIE tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "ES"
  ]
}
