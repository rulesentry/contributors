{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.indian_vehicle_registration",
  "qualified_id": "core.government.indian_vehicle_registration",
  "type": "rule",
  "version": "3.0.0",
  "name": "Indian Vehicle Registration Number",
  "description": "Detects Indian vehicle registration plate numbers in standard format. Format: 2-letter state code + 2-digit district code + 1-2 letter series + 4-digit number.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "low",
  "profiles": [
    "production"
  ],
  "metadata": {
    "country": "India",
    "pattern_source": "Based on Presidio InVehicleRegistrationRecognizer (high-confidence formats only)",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "AA00AA0000 or AA00A0000 (state + district + series + number)",
    "note": "Only standard formats included (Presidio score >= 0.50); very weak formats omitted to reduce false positives",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 50,
    "target": "content",
    "pattern": {
      "pattern": "\\b[A-Z]{2}[- ]?\\d{2}[- ]?[A-Z]{1,2}[- ]?\\d{4}\\b",
      "engine": "regex",
      "validator": "context_filter",
      "validator_params": {
        "reject_keywords": ["example", "sample", "test", "demo"]
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[IN_VEHICLE_REG]"
        }
      },
      "message": "Indian vehicle registration number redacted"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-17T00:00:00Z",
  "regions": [
    "IN"
  ]
}
