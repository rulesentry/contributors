{
  "$schema": "https://schemas.rulesentry.io/schema/v3/core/rule.schema.json",
  "id": "government.eu_it_driver_license",
  "qualified_id": "core.government.eu_it_driver_license",
  "type": "rule",
  "version": "3.0.1",
  "name": "Italian Driver License Number",
  "description": "Detects Italian driver license numbers. Two formats: standard (AA1234567A) and newer U1-prefix format.",
  "category_id": "government",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "government-sector",
    "gdpr",
    "production"
  ],
  "metadata": {
    "country": "Italy",
    "pattern_source": "Based on Presidio ItDriverLicenseRecognizer",
    "attribution": "https://github.com/microsoft/presidio",
    "format": "Standard: AA1234567A | Newer: U1XXXXXXXC",
    "official_name": "Patente di Guida",
    "needs_review": false
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 70,
    "target": "content",
    "pattern": {
      "pattern": "\\b(?:[A-Z]{2}\\d{7}[A-Z]|U1[BCDEFGHLJKMNPRSTUWYXZ0-9]{7}[A-Z])\\b",
      "engine": "regex",
      "flags": {
        "case_insensitive": true
      }
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "tokenize",
        "params": {
          "prefix": "IT_DL",
          "reversible": false
        }
      },
      "message": "Italian driver license number tokenized for de-identification"
    }
  },
  "status": "active",
  "created_at": "2026-03-17T00:00:00Z",
  "updated_at": "2026-03-21T00:00:00Z",
  "regions": [
    "IT"
  ]
}
