{
  "$schema": "../../json-schema/rule.schema.json",
  "id": "contact.th-phone-number",
  "qualified_id": "community.rulesentry.contact.th-phone-number",
  "type": "rule",
  "version": "1.0.0",
  "name": "Thailand Phone Number",
  "description": "Detects Thai phone numbers in international (+66) and local formats. Covers mobile numbers (08X/09X, 10 digits) and landline numbers (02-XXX-XXXX, 9 digits).",
  "category_id": "contact",
  "rule_kind": "atomic",
  "severity": "medium",
  "profiles": [
    "production"
  ],
  "metadata": {
    "country": "Thailand",
    "phone_format": "E.164 and local 9/10-digit"
  },
  "evaluation": {
    "evaluation_type": "pattern_match",
    "priority": 50,
    "target": "content",
    "pattern": {
      "pattern": "(?:\\+66[\\s-]?)?0[2-9][0-9][\\s-]?\\d{3}[\\s-]?\\d{4}\\b",
      "engine": "regex"
    },
    "effect": {
      "type": "transform",
      "rationale": "compliance",
      "transform": {
        "type": "redact",
        "params": {
          "marker": "[TH-PHONE]"
        }
      },
      "message": "Thailand phone number redacted"
    }
  },
  "status": "active",
  "created_at": "2026-03-05T00:00:00Z",
  "updated_at": "2026-03-05T00:00:00Z",
  "regions": [
    "TH"
  ],
  "origin": {
    "source_type": "local",
    "publisher": "experimenti",
    "author": "John"
  }
}
